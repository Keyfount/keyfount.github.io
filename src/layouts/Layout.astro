---
import "~/styles/global.css";
import { useT, pathHelper } from "~/i18n/index.js";
import { LOCALES, type Locale } from "~/i18n/translations.js";

interface Props {
  locale: Locale;
  title?: string;
  description?: string;
  /** Path without the locale prefix (e.g. "/", "/try"). */
  path: string;
}

const { locale, title, description, path } = Astro.props;
const t = useT(locale);

const fullTitle = title ?? t("meta_title");
const fullDescription = description ?? t("meta_description");

const canonical = new URL(`${pathHelper(locale).to(path)}`, Astro.site).toString();
const ogImage = new URL(`${import.meta.env.BASE_URL}/og.png`, Astro.site).toString();

const alternates = LOCALES.map((loc) => ({
  locale: loc,
  href: new URL(`${pathHelper(loc).to(path)}`, Astro.site).toString(),
}));

const structuredData = {
  "@context": "https://schema.org",
  "@type": "SoftwareApplication",
  name: "ItsMyPassword",
  applicationCategory: "BrowserApplication",
  operatingSystem: "Chrome",
  description: fullDescription,
  url: canonical,
  offers: { "@type": "Offer", price: "0", priceCurrency: "USD" },
  publisher: {
    "@type": "Organization",
    name: "ItsMyPassword",
    url: "https://github.com/ItsMyPassword",
  },
  license: "https://opensource.org/licenses/MIT",
};
---

<!doctype html>
<html lang={locale} class="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <meta name="color-scheme" content="dark" />
    <meta name="theme-color" content="#0a0a10" />

    <title>{fullTitle}</title>
    <meta name="description" content={fullDescription} />
    <link rel="canonical" href={canonical} />

    {alternates.map((alt) => <link rel="alternate" hreflang={alt.locale} href={alt.href} />)}
    <link rel="alternate" hreflang="x-default" href={alternates[0]!.href} />

    <link rel="icon" type="image/svg+xml" href={`${import.meta.env.BASE_URL}/logo.svg`} />

    <meta property="og:type" content="website" />
    <meta property="og:locale" content={locale === "fr" ? "fr_FR" : "en_US"} />
    <meta property="og:url" content={canonical} />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={fullDescription} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:site_name" content="ItsMyPassword" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={fullDescription} />
    <meta name="twitter:image" content={ogImage} />

    <script is:inline type="application/ld+json" set:html={JSON.stringify(structuredData)} />
  </head>
  <body class="min-h-screen overflow-x-hidden">
    <slot />
  </body>
</html>
