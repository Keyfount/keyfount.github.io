---
import Layout from "~/layouts/Layout.astro";
import Footer from "~/components/Footer.astro";
import { useT, pathHelper } from "~/i18n/index.js";
import type { Locale } from "~/i18n/translations.js";

interface Props {
  locale: Locale;
  title: string;
  lastUpdated: string;
  /** Path without the locale prefix, e.g. "/legal/terms". */
  path: string;
}

const { locale, title, lastUpdated, path } = Astro.props;
const t = useT(locale);
const home = pathHelper(locale).to("/");
---

<Layout locale={locale} path={path} title={`${title} — Keyfount`}>
  <main class="relative isolate px-6 py-32 sm:py-40">
    <article class="prose-legal mx-auto flex w-full max-w-3xl flex-col gap-10">
      <header class="flex flex-col gap-4">
        <a
          href={home}
          class="mono-tag inline-flex w-fit items-center gap-2 text-(--color-ink-3) transition-colors hover:text-(--color-ink-0)"
        >
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" class="h-3.5 w-3.5">
            <path d="M19 12H5M12 19l-7-7 7-7" stroke-linecap="round" stroke-linejoin="round" />
          </svg>
          {t("legal_back")}
        </a>
        <h1
          class="m-0 text-4xl font-semibold tracking-[-0.025em] text-(--color-ink-0) sm:text-5xl"
        >
          {title}
        </h1>
        <p class="m-0 mono-tag">
          {t("legal_last_updated")} · {lastUpdated}
        </p>
      </header>

      <div class="flex flex-col gap-6 text-(--color-ink-1) leading-relaxed">
        <slot />
      </div>
    </article>
  </main>
  <Footer locale={locale} path={path} />
</Layout>

<style is:global>
  .prose-legal h2 {
    margin: 1.4em 0 0.4em;
    font-size: 1.35rem;
    font-weight: 600;
    letter-spacing: -0.01em;
    color: var(--color-ink-0);
  }
  .prose-legal h3 {
    margin: 1em 0 0.2em;
    font-size: 1.05rem;
    font-weight: 600;
    color: var(--color-ink-0);
  }
  .prose-legal p {
    margin: 0;
    text-wrap: pretty;
  }
  .prose-legal ul {
    margin: 0;
    padding-left: 1.2em;
    display: flex;
    flex-direction: column;
    gap: 0.35em;
  }
  .prose-legal li::marker {
    color: var(--color-ink-3);
  }
  .prose-legal a {
    color: var(--color-ink-0);
    text-decoration: underline;
    text-underline-offset: 3px;
    text-decoration-color: var(--color-ink-4);
    transition: text-decoration-color 0.15s ease;
  }
  .prose-legal a:hover {
    text-decoration-color: var(--color-ink-0);
  }
  .prose-legal code {
    font-family: var(--font-mono);
    font-size: 0.92em;
    padding: 0.1em 0.35em;
    background: var(--color-bg-1);
    border: 1px solid var(--color-ink-5);
    border-radius: 4px;
  }
</style>
