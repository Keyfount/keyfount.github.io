---
import { useT } from "~/i18n/index.js";
import type { Locale } from "~/i18n/translations.js";

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = useT(locale);

const claims = [
  { label: t("promise_no_vault"), body: t("promise_no_vault_body") },
  { label: t("promise_no_cloud"), body: t("promise_no_cloud_body") },
  { label: t("promise_no_telemetry"), body: t("promise_no_telemetry_body") },
  { label: t("promise_oss"), body: t("promise_oss_body") },
];
---

<section class="relative isolate border-t border-(--color-ink-5) px-6 py-32">
  <div class="mx-auto flex w-full max-w-5xl flex-col gap-12">
    <header class="flex max-w-2xl flex-col gap-4">
      <span class="mono-tag">{t("promise_tag")}</span>
      <h2 class="m-0 text-4xl font-semibold tracking-[-0.025em] text-(--color-ink-0) sm:text-5xl">
        {t("promise_title")}
      </h2>
      <p class="m-0 text-pretty text-(--color-ink-2) sm:text-lg">{t("promise_body")}</p>
    </header>

    <ul class="grid grid-cols-1 gap-4 sm:grid-cols-2">
      {
        claims.map((claim) => (
          <li class="surface flex flex-col gap-3">
            <span class="font-mono text-[11px] uppercase tracking-[0.2em] text-(--color-ink-3)">
              {claim.label}
            </span>
            <p class="m-0 text-pretty text-(--color-ink-1)">{claim.body}</p>
          </li>
        ))
      }
    </ul>
  </div>
</section>
