---
import Layout from "~/layouts/Layout.astro";
import Hero from "./Hero.astro";
import HowItWorks from "./HowItWorks.astro";
import Promise from "./Promise.astro";
import TrySection from "./TrySection.astro";
import Install from "./Install.astro";
import Footer from "./Footer.astro";
import type { Locale } from "~/i18n/translations.js";

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
---

<Layout locale={locale} path="/">
  <Hero locale={locale} />
  <HowItWorks locale={locale} />
  <Promise locale={locale} />
  <TrySection locale={locale} />
  <Install locale={locale} />
  <Footer locale={locale} path="/" />
</Layout>
