---
import { useT } from "~/i18n/index.js";
import type { Locale } from "~/i18n/translations.js";

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = useT(locale);
---

<section class="relative isolate border-t border-(--color-ink-5) px-6 py-32">
  <div data-reveal class="mx-auto flex w-full max-w-3xl flex-col items-center gap-8 text-center">
    <span class="mono-tag">{t("install_tag")}</span>
    <h2 class="m-0 text-4xl font-semibold tracking-[-0.025em] text-(--color-ink-0) sm:text-5xl">
      {t("install_title")}
    </h2>
    <p class="m-0 max-w-xl text-pretty text-(--color-ink-2) sm:text-lg">{t("install_body")}</p>
    <div class="mt-2 flex flex-wrap items-center justify-center gap-3">
      <a
        href="https://github.com/Keyfount/extension"
        target="_blank"
        rel="noopener noreferrer"
        class="btn-primary"
      >
        <svg viewBox="0 0 24 24" fill="currentColor" class="h-4 w-4" aria-hidden="true">
          <path
            d="M12 .5A11.5 11.5 0 0 0 .5 12a11.5 11.5 0 0 0 7.86 10.9c.58.1.79-.25.79-.56v-2c-3.2.69-3.88-1.55-3.88-1.55-.52-1.33-1.28-1.68-1.28-1.68-1.05-.72.08-.7.08-.7 1.16.08 1.77 1.2 1.77 1.2 1.03 1.77 2.7 1.26 3.36.97.1-.75.4-1.26.73-1.55-2.55-.29-5.24-1.28-5.24-5.7 0-1.26.45-2.29 1.18-3.1-.12-.3-.51-1.48.11-3.08 0 0 .97-.31 3.18 1.18a11 11 0 0 1 5.79 0c2.2-1.49 3.17-1.18 3.17-1.18.62 1.6.23 2.78.11 3.08.74.81 1.18 1.84 1.18 3.1 0 4.43-2.7 5.4-5.26 5.69.41.35.78 1.05.78 2.12v3.14c0 .31.21.67.8.56A11.5 11.5 0 0 0 23.5 12 11.5 11.5 0 0 0 12 .5Z"
          ></path>
        </svg>
        {t("install_get_source")}
      </a>
      <a href="#try" class="btn-ghost">{t("hero_cta_try")}</a>
    </div>
  </div>
</section>
