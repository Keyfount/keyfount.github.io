---
import { pathHelper, useT } from "~/i18n/index.js";
import type { Locale } from "~/i18n/translations.js";

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = useT(locale);
const p = pathHelper(locale);
---

<section class="relative isolate border-t border-(--color-ink-5) px-6 py-32">
  <div class="mx-auto flex w-full max-w-3xl flex-col items-center gap-8 text-center">
    <span class="mono-tag">{t("install_tag")}</span>
    <h2 class="m-0 text-4xl font-semibold tracking-[-0.025em] text-(--color-ink-0) sm:text-5xl">
      {t("install_title")}
    </h2>
    <p class="m-0 max-w-xl text-pretty text-(--color-ink-2) sm:text-lg">{t("install_body")}</p>
    <div class="mt-2 flex flex-wrap items-center justify-center gap-3">
      <a href={p.to("/try")} class="btn-primary">
        <svg
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="1.8"
          stroke-linecap="round"
          stroke-linejoin="round"
          class="h-4 w-4"
          aria-hidden="true"
        >
          <path d="M13 2 4.5 13.5h6L11 22l8.5-11.5h-6L13 2Z"></path>
        </svg>
        {t("hero_cta_try")}
      </a>
      <a
        href="https://github.com/ItsMyPassword/extension"
        target="_blank"
        rel="noopener noreferrer"
        class="btn-ghost"
      >
        {t("install_get_source")}
      </a>
    </div>
  </div>
</section>
