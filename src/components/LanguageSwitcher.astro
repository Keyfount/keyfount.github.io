---
import { pathHelper, useT } from "~/i18n/index.js";
import { LOCALES, LOCALE_LABELS, type Locale } from "~/i18n/translations.js";

interface Props {
  /** Active locale. */
  locale: Locale;
  /** Path without the locale prefix (e.g. "/", "/try"). */
  path: string;
}

const { locale, path } = Astro.props;
const t = useT(locale);
---

<nav
  class="flex items-center gap-1.5 font-mono text-[10px] uppercase tracking-[0.22em]"
  aria-label={t("lang_switcher_label")}
>
  {
    LOCALES.map((loc, index) => (
      <>
        {index > 0 ? <span class="text-(--color-ink-4)">·</span> : null}
        <a
          href={pathHelper(loc).to(path)}
          aria-current={loc === locale ? "true" : "false"}
          class:list={[
            "transition-colors duration-150",
            loc === locale
              ? "text-(--color-ink-0)"
              : "text-(--color-ink-4) hover:text-(--color-ink-1)",
          ]}
          hreflang={loc}
        >
          {LOCALE_LABELS[loc]}
        </a>
      </>
    ))
  }
</nav>
