---
import { useT } from "~/i18n/index.js";
import type { Locale } from "~/i18n/translations.js";

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = useT(locale);

/**
 * Localised strings shipped to the client-side generator as a single
 * data attribute. Keeping the contract here means the script itself
 * stays string-agnostic.
 */
const generatorStrings = {
  tryMaster: t("try_master"),
  trySite: t("try_site"),
  trySitePlaceholder: t("try_site_placeholder"),
  tryEmail: t("try_email"),
  tryEmailPlaceholder: t("try_email_placeholder"),
  tryMode: t("try_mode"),
  tryModeRandom: t("try_mode_random"),
  tryModeMemorable: t("try_mode_memorable"),
  tryLength: t("try_length"),
  tryWords: t("try_words"),
  trySeparator: t("try_separator"),
  tryCounter: t("try_counter"),
  tryClasses: t("try_classes"),
  tryClassLower: t("try_class_lower"),
  tryClassUpper: t("try_class_upper"),
  tryClassDigits: t("try_class_digits"),
  tryClassSymbols: t("try_class_symbols"),
  tryCapitalise: t("try_capitalise"),
  trySuffix: t("try_suffix"),
  tryGenerate: t("try_generate"),
  tryGenerating: t("try_generating"),
  tryIdle: t("try_idle"),
  trySettings: t("try_settings"),
  tryResult: t("try_result"),
  tryCopy: t("try_copy"),
  tryCopied: t("try_copied"),
  tryReveal: t("try_reveal"),
  tryHide: t("try_hide"),
  tryDisclaimer: t("try_disclaimer"),
  tryMinMaster: t("try_min_master"),
};
---

<section id="try" class="relative isolate border-t border-(--color-ink-5) px-6 py-32 scroll-mt-16">
  <div class="mx-auto flex w-full max-w-5xl flex-col gap-8">
    <header data-reveal class="flex flex-col gap-4 text-center">
      <span class="mono-tag mx-auto">{t("install_tag")}</span>
      <h2
        class="headline-gradient m-0 font-extrabold tracking-[-0.025em] leading-[1.05]"
        style="font-size: clamp(40px, 5vw, 64px);"
      >
        {t("try_title")}
      </h2>
      <p class="m-0 text-pretty text-(--color-ink-2) sm:text-lg">{t("try_body")}</p>
    </header>

    <div id="generator-root" data-strings={JSON.stringify(generatorStrings)}></div>
  </div>
</section>

<script>
  import { mountGenerator } from "~/scripts/generator.ts";

  const root = document.getElementById("generator-root");
  if (root !== null) {
    const strings = JSON.parse(root.dataset.strings ?? "{}");
    mountGenerator({ root, strings });
  }
</script>
