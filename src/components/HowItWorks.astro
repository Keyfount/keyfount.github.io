---
import { useT } from "~/i18n/index.js";
import type { Locale } from "~/i18n/translations.js";

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = useT(locale);

const steps = [
  { label: "01", title: t("how_step1_title"), body: t("how_step1_body") },
  { label: "02", title: t("how_step2_title"), body: t("how_step2_body") },
  { label: "03", title: t("how_step3_title"), body: t("how_step3_body") },
];
---

<section id="how-it-works" class="relative isolate border-t border-(--color-ink-5) px-6 py-32">
  <div class="mx-auto flex w-full max-w-5xl flex-col gap-16">
    <header data-reveal class="flex max-w-2xl flex-col gap-4">
      <span class="mono-tag">{t("how_tag")}</span>
      <h2 class="m-0 text-4xl font-semibold tracking-[-0.025em] text-(--color-ink-0) sm:text-5xl">
        {t("how_title")}
      </h2>
      <p class="m-0 text-pretty text-(--color-ink-2) sm:text-lg">{t("how_body")}</p>
    </header>

    <ol
      data-reveal-stagger
      class="grid grid-cols-1 gap-px overflow-hidden rounded-2xl border border-(--color-ink-5) bg-(--color-ink-5) sm:grid-cols-3"
    >
      {
        steps.map((step) => (
          <li class="flex flex-col gap-4 bg-(--color-bg-1) p-8">
            <span class="mono-tag">{step.label}</span>
            <h3 class="m-0 text-xl font-semibold tracking-[-0.015em] text-(--color-ink-0)">
              {step.title}
            </h3>
            <p class="m-0 text-pretty text-sm leading-relaxed text-(--color-ink-2)">{step.body}</p>
          </li>
        ))
      }
    </ol>
  </div>
</section>
